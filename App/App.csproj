<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <RootNamespace>DocumentationImageHelper</RootNamespace>
    <AssemblyName>DocumentationImageHelper</AssemblyName>
    <ApplicationIcon>..\markup.ico</ApplicationIcon>
  </PropertyGroup>

  <!-- The icon lives at the repo root; link it in so the window can load it as a resource. -->
  <ItemGroup>
    <Resource Include="..\markup.ico">
      <Link>markup.ico</Link>
    </Resource>
  </ItemGroup>

</Project>
